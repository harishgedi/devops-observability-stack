# DevOps Observability Stack Environment Configuration
# Copy this file to .env and update with your values

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_USERNAME=your_github_username
GITHUB_REPO_NAME=devops-observability-stack
GITHUB_REPO_DESCRIPTION=Enterprise-grade DevOps observability stack with Prometheus, Grafana, and AlertManager

# Grafana Configuration
GF_SECURITY_ADMIN_PASSWORD=your_secure_grafana_password
GF_SECURITY_ADMIN_USER=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_SECURITY_ALLOW_EMBEDDING=true

# AlertManager Configuration
ALERTMANAGER_SMARTHOST=smtp.gmail.com:587
ALERTMANAGER_SMTP_FROM=alerts@yourdomain.com
ALERTMANAGER_SMTP_USER=your_email@gmail.com
ALERTMANAGER_SMTP_PASSWORD=your_app_password
ALERTMANAGER_SMTP_TLS=true

# Slack Configuration (Optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Application Configuration
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true
COLLECTION_INTERVAL=10
ENABLE_DOCKER=true
ENABLE_CONTAINERS=true

# Monitoring Service Configuration
HOSTNAME=localhost
API_HOST=0.0.0.0
API_PORT=8000

# External Service URLs
GRAFANA_URL=http://admin:your_secure_grafana_password@grafana:3000
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093
